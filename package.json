  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "vendor:dev": "NODE_ENV=development node esbuild.vendor.config.js",
